PYTHON_VERSION=3.11.11

# CoinGecko free/demo key. Any of these names works in the app, but using this one is simplest:
COINGECKO_API_KEY=

# Optional: "demo" for free keys, "pro" for paid keys
COINGECKO_API_PLAN=demo

# Optional override. Leave as-is for demo/free keys.
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
